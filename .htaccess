# PERPUSTAKAAN DYZEN - Apache Security Configuration

# Disable directory listing
Options -Indexes
Options -MultiViews

# Enable rewrite engine
RewriteEngine On

# ============================================
# SECURITY HEADERS
# ============================================
<IfModule mod_headers.c>
    Header set X-Frame-Options "DENY"
    Header set X-XSS-Protection "1; mode=block"
    Header set X-Content-Type-Options "nosniff"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    Header unset X-Powered-By
    Header unset Server
</IfModule>

# ============================================
# BLOCK ACCESS TO SENSITIVE FILES
# ============================================
<FilesMatch "\.(ini|log|sql|bak|config|env|sh|bash)$">
    Require all denied
</FilesMatch>

<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Block access to config directory
RewriteRule ^config/ - [F,L]

# Block access to logs directory
RewriteRule ^logs/ - [F,L]

# Block access to uploads except images
<IfModule mod_rewrite.c>
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteCond %{REQUEST_URI} ^/uploads/ [NC]
    RewriteCond %{REQUEST_FILENAME} !\.(jpg|jpeg|png|gif|webp)$ [NC]
    RewriteRule .* - [F,L]
</IfModule>

# ============================================
# SQL INJECTION PROTECTION
# ============================================
RewriteCond %{QUERY_STRING} (\<|%3C).*script.*(\>|%3E) [NC,OR]
RewriteCond %{QUERY_STRING} GLOBALS(=|\[|\%[0-9A-Z]{0,2}) [OR]
RewriteCond %{QUERY_STRING} _REQUEST(=|\[|\%[0-9A-Z]{0,2}) [OR]
RewriteCond %{QUERY_STRING} (SELECT|INSERT|UPDATE|DELETE|DROP|ALTER|CREATE|TRUNCATE|UNION|DECLARE|EXEC|EXECUTE) [NC]
RewriteRule .* - [F,L]

# ============================================
# PREVENT HOTLINKING
# ============================================
RewriteCond %{HTTP_REFERER} !^$
RewriteCond %{HTTP_REFERER} !^http(s)?://(www\.)?localhost [NC]
RewriteRule \.(jpg|jpeg|png|gif|webp)$ - [F,L]

# ============================================
# COMPRESSION
# ============================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# ============================================
# CACHE CONTROL
# ============================================
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>

# ============================================
# CUSTOM ERROR PAGES
# ============================================
ErrorDocument 403 /error/403.html
ErrorDocument 404 /error/404.html
ErrorDocument 500 /error/500.html

# ============================================
# REDIRECT TRAILING SLASH
# ============================================
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} /$
RewriteRule ^(.*)/$ /$1 [R=301,L]

# ============================================
# FORCE HTTPS (Uncomment when using SSL)
# ============================================
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# Custom Error Pages
ErrorDocument 404 /perpustakaan_dyzen/error/404.html
ErrorDocument 403 /perpustakaan_dyzen/error/403.html
ErrorDocument 500 /perpustakaan_dyzen/error/500.html

# Maintenance Mode - redirect semua pengunjung ke halaman maintenance
